# .dockerignore — 防止 COPY . . 把不需要的文件打入镜像

# 环境变量（已在 docker-compose environment 中注入）
.env
.env.local
.env.*.local
*.pem
*.key

# Node.js 依赖（构建时重新 npm install）
node_modules/

# Next.js 构建产物（构建时重新 build）
web/.next/
web/out/

# Flutter 构建产物和 SDK
mobile/
flutter-sdk/

# SQLite 数据库（通过 volume 挂载持久化）
backend/data/*.db
backend/data/*.db-wal
backend/data/*.db-shm

# 日志
logs/
*.log

# IDE 和编辑器
.idea/
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# 文档（不需要打进镜像）
docs/
*.md

# 其他
.DS_Store
Thumbs.db
desktop.ini
tmp/
temp/
coverage/
