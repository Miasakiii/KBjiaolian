/* pages/chat/index.wxss - AI 对话页 */
.chat-page { display: flex; flex-direction: column; height: 100vh; padding: 0; }
.page-container { min-height: 100vh; background: var(--bg); }

/* 登录提示 */
.login-prompt { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.login-icon-wrap { margin-bottom: var(--sp-3); }
.login-icon-img { width: 96rpx; height: 96rpx; opacity: 0.4; }
.lp-text { font-size: var(--fs-body); color: var(--text-3); margin-bottom: var(--sp-4); }
.lp-btn { width: 60%; }

/* 消息列表 */
.chat-list { flex: 1; padding: var(--sp-3) var(--sp-4); }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: var(--brand-soft); display: flex; align-items: center; justify-content: center; margin-bottom: var(--sp-3); }
.empty-avatar-icon { width: 48rpx; height: 48rpx; }
.empty-text { font-size: var(--fs-body); color: var(--text-1); font-weight: 600; margin-bottom: var(--sp-1); }
.empty-hint { font-size: var(--fs-caption); color: var(--text-3); }

/* 消息气泡 */
.msg-item { display: flex; align-items: flex-start; gap: var(--sp-2); margin-bottom: var(--sp-3); }
.msg-user { flex-direction: row-reverse; }
.msg-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.msg-avatar-ai { background: var(--brand-soft); }
.msg-avatar-user { background: var(--surface-2); border: 1rpx solid var(--line-soft); }
.msg-avatar-icon { width: 34rpx; height: 34rpx; opacity: 0.7; }
.msg-bubble { max-width: 70%; padding: var(--sp-2) var(--sp-3); border-radius: var(--radius); }
.msg-ai .msg-bubble { background: var(--surface); border: 1rpx solid var(--line-soft); border-top-left-radius: 4rpx; }
.msg-user .msg-bubble { background: var(--brand); color: #fff; border-top-right-radius: 4rpx; }
.msg-text { font-size: var(--fs-body); line-height: 1.6; }
.msg-user .msg-text { color: #fff; }
.msg-time { font-size: var(--fs-label); color: var(--text-3); margin-top: 6rpx; }
.msg-user .msg-time { color: rgba(255,255,255,0.7); }

/* 打字动画 */
.msg-typing { display: flex; gap: 8rpx; align-items: center; }
.typing-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--text-3); animation: typing 1.4s infinite; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing { 0%, 60%, 100% { opacity: 0.3; transform: translateY(0); } 30% { opacity: 1; transform: translateY(-6rpx); } }

/* 快捷提问 */
.quick-prompts { padding: 0 var(--sp-4) var(--sp-3); display: flex; flex-wrap: wrap; gap: var(--sp-2); }
.qp-item { padding: 12rpx 24rpx; border-radius: 20rpx; font-size: var(--fs-caption); color: var(--brand); background: var(--brand-soft); border: 1rpx solid var(--brand-soft); }
.qp-item:active { opacity: 0.85; }

/* 输入栏 */
.input-bar { display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-2) var(--sp-4) calc(var(--sp-2) + env(safe-area-inset-bottom)); background: var(--surface); border-top: 1rpx solid var(--line-soft); }
.input-field { flex: 1; background: var(--surface-2); border: 1rpx solid var(--line-soft); border-radius: var(--radius); padding: 16rpx 24rpx; font-size: var(--fs-body); color: var(--text-1); }
.send-btn { padding: 16rpx 32rpx; border-radius: var(--radius-sm); font-size: var(--fs-caption); color: #fff; background: var(--line); }
.send-btn-active { background: var(--brand); font-weight: 600; }
.send-btn:active { opacity: 0.85; }
