/* pages/chat/index.wxss - AI 对话页样式（优化版） */
.page-container { height: 100vh; display: flex; flex-direction: column; background: #f0f2f5; }

/* 登录提示 */
.login-prompt { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.lp-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.lp-text { font-size: 28rpx; color: #6b7280; margin-bottom: 32rpx; }
.lp-btn { width: 60% !important; }

/* 消息列表 */
.chat-list { flex: 1; height: 0; padding: 20rpx 20rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; font-weight: 600; color: #374151; margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: #9ca3af; }

/* 消息气泡 */
.msg-item { display: flex; align-items: flex-start; margin-bottom: 20rpx; }
.msg-user { flex-direction: row-reverse; }
.msg-avatar {
  width: 68rpx; height: 68rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 34rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.msg-ai .msg-avatar { background: linear-gradient(135deg, #22c55e, #16a34a); }
.msg-user .msg-avatar { background: linear-gradient(135deg, #6366f1, #8b5cf6); }

.msg-bubble {
  max-width: 72%; margin: 0 16rpx; padding: 20rpx 24rpx;
  border-radius: 20rpx; font-size: 26rpx; line-height: 1.7;
  word-break: break-all; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.msg-ai .msg-bubble {
  background: #ffffff; color: #1c1c1e;
  border-top-left-radius: 6rpx;
}
.msg-user .msg-bubble {
  background: linear-gradient(135deg, #22c55e, #16a34a); color: #ffffff;
  border-top-right-radius: 6rpx;
}

/* rich-text 内容区 */
.msg-text { display: block; }
.msg-ai .msg-text { color: #1c1c1e; }
.msg-user .msg-text { color: #ffffff; }

.msg-time { font-size: 20rpx; color: #9ca3af; margin-top: 8rpx; }

/* typing 动画 */
.msg-typing { padding: 24rpx 32rpx !important; display: flex; align-items: center; gap: 8rpx; }
.typing-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%; background: #9ca3af;
  animation: blink 1.2s infinite both;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink { 0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); } 40% { opacity: 1; transform: scale(1); } }

/* 快捷提问 */
.quick-prompts {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  padding: 16rpx 20rpx; justify-content: center;
}
.qp-item {
  background: #ffffff; border: 2rpx solid #e5e7eb; border-radius: 32rpx;
  padding: 12rpx 24rpx; font-size: 24rpx; color: #374151;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.qp-item:active { background: #f0fdf4; border-color: #22c55e; }

/* 输入栏 */
.input-bar {
  display: flex; align-items: flex-end; gap: 12rpx;
  padding: 16rpx 20rpx; background: #ffffff;
  border-top: 1rpx solid #e5e7eb; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.04);
}
.input-field {
  flex: 1; background: #f1f5f9; border-radius: 16rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; min-height: 40rpx; max-height: 160rpx;
}
.send-btn {
  padding: 16rpx 28rpx; border-radius: 16rpx;
  background: #d1d5db; color: #ffffff; font-size: 26rpx; font-weight: 500;
  transition: background 0.2s;
}
.send-btn-active { background: linear-gradient(135deg, #22c55e, #16a34a); }
.send-btn:active { opacity: 0.85; }
