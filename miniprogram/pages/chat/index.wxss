/* pages/chat/index.wxss - AI 对话页样式 */
.page-container { height: 100vh; display: flex; flex-direction: column; background: #f8fafb; }

/* 登录提示 */
.login-prompt { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.login-icon-wrap {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: #f0fdf4; display: flex; align-items: center; justify-content: center;
  margin-bottom: 28rpx;
}
.login-icon-char { font-size: 40rpx; font-weight: 700; color: #22c55e; }
.lp-text { font-size: 28rpx; color: #9ca3af; margin-bottom: 36rpx; }
.lp-btn { width: 60% !important; }

/* 消息列表 */
.chat-list { flex: 1; height: 0; padding: 20rpx 20rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 100rpx 40rpx 60rpx; }
.empty-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, #22c55e, #059669);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.2);
}
.empty-avatar-text { font-size: 40rpx; font-weight: 800; color: #ffffff; }
.empty-text { font-size: 30rpx; font-weight: 600; color: #111827; margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: #9ca3af; }

/* 消息气泡 */
.msg-item { display: flex; align-items: flex-start; margin-bottom: 24rpx; }
.msg-user { flex-direction: row-reverse; }

/* 头像 - CSS 圆形替代 emoji */
.msg-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.msg-avatar-ai {
  background: linear-gradient(135deg, #22c55e, #059669);
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.2);
}
.msg-avatar-user {
  background: #f3f4f6;
}
.msg-avatar-text { font-size: 26rpx; font-weight: 700; color: #ffffff; }
.msg-avatar-user .msg-avatar-text { color: #4b5563; }

.msg-bubble {
  max-width: 72%; margin: 0 16rpx; padding: 22rpx 28rpx;
  border-radius: 24rpx; font-size: 26rpx; line-height: 1.7;
  word-break: break-all;
}
.msg-ai .msg-bubble {
  background: #ffffff; color: #111827;
  border-top-left-radius: 8rpx;
  border: 1rpx solid #f0f0f0;
}
.msg-user .msg-bubble {
  background: linear-gradient(135deg, #22c55e, #16a34a); color: #ffffff;
  border-top-right-radius: 8rpx;
}

/* rich-text 内容区 */
.msg-text { display: block; }
.msg-ai .msg-text { color: #111827; }
.msg-user .msg-text { color: #ffffff; }

.msg-time { font-size: 20rpx; margin-top: 8rpx; }
.msg-ai .msg-time { color: #9ca3af; }
.msg-user .msg-time { color: rgba(255,255,255,0.7); }

/* typing 动画 */
.msg-typing { padding: 28rpx 36rpx !important; display: flex; align-items: center; gap: 10rpx; }
.typing-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%; background: #d1d5db;
  animation: blink 1.2s infinite both;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink { 0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); } 40% { opacity: 1; transform: scale(1); } }

/* 快捷提问 */
.quick-prompts {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  padding: 16rpx 20rpx; justify-content: center;
}
.qp-item {
  background: #ffffff; border: 1rpx solid #e5e7eb; border-radius: 32rpx;
  padding: 14rpx 28rpx; font-size: 24rpx; color: #4b5563;
}
.qp-item:active { background: #f0fdf4; border-color: #22c55e; color: #16a34a; }

/* 输入栏 */
.input-bar {
  display: flex; align-items: flex-end; gap: 12rpx;
  padding: 16rpx 20rpx; background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.03);
}
.input-field {
  flex: 1; background: #f8fafb; border-radius: 20rpx;
  padding: 18rpx 24rpx; font-size: 28rpx; min-height: 40rpx; max-height: 160rpx;
  border: 1rpx solid #f0f0f0;
}
.input-field:focus { border-color: #22c55e; background: #ffffff; }
.send-btn {
  padding: 18rpx 32rpx; border-radius: 20rpx;
  background: #e5e7eb; color: #ffffff; font-size: 26rpx; font-weight: 600;
  transition: background 0.2s;
}
.send-btn-active { background: linear-gradient(135deg, #22c55e, #16a34a); }
.send-btn:active { opacity: 0.85; }
