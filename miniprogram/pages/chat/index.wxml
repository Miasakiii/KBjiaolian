<!--pages/chat/index.wxml - AI 对话页-->
<view class="page-container chat-page">
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <view class="login-icon-wrap">
      <image src="/assets/icons/ic-user.svg" mode="aspectFit" class="login-icon-img" />
    </view>
    <text class="lp-text">登录后可使用 AI 对话</text>
    <button class="btn-primary lp-btn" bindtap="onTapLogin">去登录</button>
  </view>

  <block wx:else>
    <!-- 消息列表 -->
    <scroll-view class="chat-list" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation>
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{messages.length === 0}}">
        <view class="empty-avatar">
          <image src="/assets/icons/tab-chat.svg" mode="aspectFit" class="empty-avatar-icon" />
        </view>
        <text class="empty-text">你好！我是 KB 教练 AI 助手</text>
        <text class="empty-hint">可以问我任何健身、康复、营养问题</text>
      </view>

      <!-- 消息气泡 -->
      <view class="msg-item {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
        <view class="msg-avatar msg-avatar-ai" wx:if="{{item.role === 'ai'}}">
          <image src="/assets/icons/tab-chat.svg" mode="aspectFit" class="msg-avatar-icon" />
        </view>
        <view class="msg-bubble">
          <rich-text class="msg-text" nodes="{{item.contentHtml || item.content}}" wx:if="{{item.role === 'ai'}}"></rich-text>
          <text class="msg-text" user-select wx:else>{{item.content}}</text>
          <view class="msg-time">{{item.time}}</view>
        </view>
        <view class="msg-avatar msg-avatar-user" wx:if="{{item.role === 'user'}}">
          <image src="/assets/icons/ic-user.svg" mode="aspectFit" class="msg-avatar-icon" />
        </view>
      </view>

      <!-- 打字中 -->
      <view class="msg-item msg-ai" wx:if="{{loading}}">
        <view class="msg-avatar msg-avatar-ai">
          <image src="/assets/icons/tab-chat.svg" mode="aspectFit" class="msg-avatar-icon" />
        </view>
        <view class="msg-bubble msg-typing">
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
        </view>
      </view>

      <view style="height: 20rpx;"></view>
    </scroll-view>

    <!-- 快捷提问 -->
    <view class="quick-prompts" wx:if="{{messages.length === 0}}">
      <view class="qp-item" wx:for="{{quickPrompts}}" wx:key="key" bindtap="onTapQuick" data-prompt="{{item.prompt}}">{{item.label}}</view>
    </view>

    <!-- 输入栏 -->
    <view class="input-bar safe-bottom">
      <input class="input-field" value="{{inputValue}}" bindinput="onInput" bindconfirm="onSend" placeholder="输入健身问题..." confirm-type="send" adjust-position />
      <view class="send-btn {{inputValue ? 'send-btn-active' : ''}}" bindtap="onSend"><text>发送</text></view>
    </view>
  </block>
</view>
