/* pages/analyze/index.wxss - 体态分析页样式 */
.page-container { min-height: 100vh; background: #f8fafc; padding-bottom: 40rpx; }

/* 未登录提示 */
.login-prompt {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 40rpx;
}
.lp-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.lp-text { font-size: 28rpx; color: #6b7280; margin-bottom: 32rpx; }
.lp-btn { width: 60% !important; }

/* 拍照引导 */
.analyze-hero {
  margin: 24rpx; padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  border-radius: 20rpx; color: #ffffff;
}
.ah-title { font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 12rpx; }
.ah-desc { font-size: 26rpx; opacity: 0.9; display: block; margin-bottom: 28rpx; }
.ah-tips { margin-bottom: 32rpx; }
.ah-tip { font-size: 24rpx; opacity: 0.85; display: block; margin-bottom: 8rpx; }
.ah-actions { display: flex; flex-direction: column; gap: 16rpx; }

/* 加载动画 */
.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0; }
.loading-spinner {
  width: 64rpx; height: 64rpx; border: 6rpx solid #e5e7eb;
  border-top-color: #22c55e; border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #374151; margin-top: 24rpx; }
.loading-sub { font-size: 22rpx; color: #9ca3af; margin-top: 8rpx; }

/* 结果页 */
.result-image-wrap { padding: 24rpx; text-align: center; }
.result-image { width: 100%; border-radius: 16rpx; }

/* 综合评分 */
.score-overview {
  display: flex; flex-direction: column; align-items: center;
  padding: 32rpx; margin: 0 24rpx 20rpx;
}
.so-title { font-size: 26rpx; color: #6b7280; margin-bottom: 12rpx; }
.so-score-wrap { display: flex; align-items: baseline; }
.so-score { font-size: 72rpx; font-weight: 700; color: #22c55e; }
.so-unit { font-size: 28rpx; color: #22c55e; margin-left: 4rpx; }
.so-level { font-size: 26rpx; color: #16a34a; margin-top: 8rpx; }

/* 维度卡片 */
.dimension-list { padding: 0 24rpx; }
.dimension-card { margin: 0 0 16rpx !important; }
.dc-header { margin-bottom: 12rpx; }
.dc-name { font-size: 28rpx; font-weight: 500; }
.dc-score { font-size: 30rpx; font-weight: 600; }
.dc-bar-bg {
  width: 100%; height: 12rpx; background: #f1f5f9;
  border-radius: 6rpx; overflow: hidden; margin: 8rpx 0;
}
.dc-bar-fill { height: 100%; border-radius: 6rpx; transition: width 0.5s; }
.dc-suggestion { font-size: 22rpx; color: #6b7280; }

/* 结果操作按钮 */
.result-actions {
  display: flex; flex-direction: column; gap: 16rpx;
  padding: 24rpx 24rpx 40rpx;
}
