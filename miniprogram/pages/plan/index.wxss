/* pages/plan/index.wxss - 训练方案页样式 */
.page-container { min-height: 100vh; background: #f8fafb; padding-bottom: 40rpx; }
.login-prompt { display: flex; flex-direction: column; align-items: center; padding: 140rpx 40rpx; }
.login-icon-wrap {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: #f0fdf4; display: flex; align-items: center; justify-content: center;
  margin-bottom: 28rpx;
}
.login-icon-char { font-size: 40rpx; font-weight: 700; color: #22c55e; }
.lp-text { font-size: 28rpx; color: #9ca3af; margin-bottom: 36rpx; }
.lp-btn { width: 60% !important; }

/* 表单 */
.plan-form {
  margin: 24rpx; padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
.pf-title { font-size: 34rpx; font-weight: 700; display: block; margin-bottom: 8rpx; color: #111827; }
.pf-desc { font-size: 26rpx; color: #9ca3af; display: block; margin-bottom: 36rpx; }
.pf-section { margin-bottom: 32rpx; }
.pf-label { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 14rpx; color: #111827; }
.pf-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.pf-option {
  padding: 16rpx 32rpx; border-radius: 12rpx; font-size: 26rpx;
  background: #f8fafb; color: #4b5563; border: 1rpx solid #f0f0f0;
}
.pf-option-active { background: #dcfce7; color: #16a34a; border-color: #22c55e; font-weight: 600; }
.pf-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.pf-tag {
  padding: 14rpx 28rpx; border-radius: 12rpx; font-size: 24rpx;
  background: #f8fafb; color: #4b5563; border: 1rpx solid #f0f0f0;
}
.pf-tag-active { background: #dcfce7; color: #16a34a; border-color: #22c55e; font-weight: 600; }

/* 方案展示 */
.plan-header {
  margin: 24rpx; padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
.ph-title { font-size: 34rpx; font-weight: 700; display: block; margin-bottom: 8rpx; color: #111827; }
.ph-desc { font-size: 26rpx; color: #9ca3af; display: block; margin-bottom: 20rpx; }
.ph-meta { display: flex; gap: 28rpx; }
.ph-meta-item { display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; color: #9ca3af; }
.ph-meta-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: #22c55e; }

/* 每日方案 */
.day-list { padding: 0 24rpx; }
.day-card { margin: 0 0 16rpx !important; }
.dc-header { padding: 4rpx 0; }
.dc-day { font-size: 28rpx; font-weight: 600; color: #111827; }
.dc-arrow { font-size: 22rpx; color: #d1d5db; }
.dc-exercises { padding-top: 16rpx; border-top: 1rpx solid #f3f4f6; margin-top: 12rpx; }
.exercise-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 14rpx 0; border-bottom: 1rpx solid #fafafa;
}
.exercise-item:last-child { border-bottom: none; }
.ei-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #dcfce7; margin-top: 14rpx; flex-shrink: 0; }
.ei-content { flex: 1; }
.ei-name { font-size: 28rpx; font-weight: 600; color: #111827; display: block; }
.ei-meta { font-size: 24rpx; color: #9ca3af; display: block; margin-top: 4rpx; }
.ei-note { font-size: 22rpx; color: #d1d5db; display: block; margin-top: 4rpx; }

.plan-actions { display: flex; flex-direction: column; gap: 16rpx; padding: 24rpx 24rpx 40rpx; }
