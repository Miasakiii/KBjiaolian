/* pages/plan/index.wxss - 训练方案页样式 */
.page-container { min-height: 100vh; background: #f8fafc; padding-bottom: 40rpx; }
.login-prompt { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.lp-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.lp-text { font-size: 28rpx; color: #6b7280; margin-bottom: 32rpx; }
.lp-btn { width: 60% !important; }

/* 表单 */
.plan-form { margin: 24rpx; }
.pf-title { font-size: 34rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.pf-desc { font-size: 26rpx; color: #6b7280; display: block; margin-bottom: 32rpx; }
.pf-section { margin-bottom: 28rpx; }
.pf-label { font-size: 28rpx; font-weight: 500; display: block; margin-bottom: 12rpx; }
.pf-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.pf-option {
  padding: 14rpx 28rpx; border-radius: 8rpx; font-size: 26rpx;
  background: #f1f5f9; color: #374151; border: 2rpx solid transparent;
}
.pf-option-active { background: #dcfce7; color: #16a34a; border-color: #22c55e; font-weight: 500; }
.pf-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.pf-tag {
  padding: 12rpx 24rpx; border-radius: 8rpx; font-size: 24rpx;
  background: #f1f5f9; color: #374151; border: 2rpx solid transparent;
}
.pf-tag-active { background: #dbeafe; color: #1d4ed; border-color: #3b82f6; }

/* 方案展示 */
.plan-header { margin: 24rpx; }
.ph-title { font-size: 34rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.ph-desc { font-size: 26rpx; color: #6b7280; display: block; margin-bottom: 16rpx; }
.ph-meta { display: flex; gap: 24rpx; }
.ph-meta-item { font-size: 24rpx; color: #6b7280; }

/* 每日方案 */
.day-list { padding: 0 24rpx; }
.day-card { margin: 0 0 16rpx !important; }
.dc-header { padding: 4rpx 0; }
.dc-day { font-size: 28rpx; font-weight: 500; }
.dc-arrow { font-size: 22rpx; color: #9ca3af; }
.dc-exercises { padding-top: 16rpx; border-top: 1rpx solid #f1f5f9; margin-top: 12rpx; }
.exercise-item {
  display: flex; align-items: baseline; gap: 16rpx;
  padding: 12rpx 0; border-bottom: 1rpx solid #f9fafb;
}
.exercise-item:last-child { border-bottom: none; }
.ei-name { font-size: 28rpx; font-weight: 500; min-width: 120rpx; }
.ei-meta { font-size: 24rpx; color: #6b7280; }
.ei-note { font-size: 22rpx; color: #9ca3af; display: block; margin-top: 4rpx; }

.plan-actions { display: flex; flex-direction: column; gap: 16rpx; padding: 24rpx 24rpx 40rpx; }
