<!--pages/index/index.wxml - 首页/仪表盘-->
<view class="page-container">
  <!-- 未登录态：宣传 Banner -->
  <block wx:if="{{!isLoggedIn}}">
    <view class="hero-banner animate-fade-in">
      <view class="hero-content">
        <view class="hero-logo">
          <text class="hero-logo-text">KB</text>
        </view>
        <text class="hero-title">拍一张照，Know Your Body</text>
        <text class="hero-subtitle">AI 驱动的体态评估与康复矫正专家</text>
        <button class="btn-primary hero-btn" bindtap="onTapLogin">微信一键登录</button>
      </view>
    </view>
    <view class="features-grid">
      <view class="feature-card tap-scale animate-fade-in animate-delay-{{index + 1}}" wx:for="{{features}}" wx:key="key">
        <view class="feature-icon-wrap">
          <image class="feature-icon-img" src="{{item.icon}}" mode="aspectFit" />
        </view>
        <text class="feature-name">{{item.name}}</text>
        <text class="feature-desc">{{item.desc}}</text>
      </view>
    </view>
  </block>

  <!-- 已登录态：仪表盘 -->
  <block wx:else>
    <!-- 欢迎语 -->
    <view class="welcome-bar animate-fade-in">
      <view>
        <text class="welcome-text">你好，{{user.nickname || '健身伙伴'}}</text>
        <text class="welcome-date">{{today}}</text>
      </view>
      <view class="plan-badge badge">{{user.plan === 'pro' ? 'Pro' : 'Free'}}</view>
    </view>

    <!-- 今日配额卡片 -->
    <view class="quota-card card animate-fade-in animate-delay-1">
      <view class="quota-header flex-between">
        <text class="quota-title">今日剩余配额</text>
        <text class="quota-upgrade" wx:if="{{user.plan !== 'pro'}}" bindtap="onTapUpgrade">升级 Pro</text>
      </view>
      <view class="quota-grid">
        <view class="quota-item" wx:for="{{quotaList}}" wx:key="key">
          <text class="quota-count">{{item.remaining}}</text>
          <text class="quota-label">{{item.label}}</text>
          <view class="quota-bar-bg">
            <view class="quota-bar-fill" style="width: {{item.percent}}%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions-wrap animate-fade-in animate-delay-2">
      <view class="quick-actions">
        <view class="quick-action" wx:for="{{quickActions}}" wx:key="key" bindtap="{{item.key === 'analyze' ? 'onTapAnalyze' : item.key === 'plan' ? 'onTapPlan' : item.key === 'chat' ? 'onTapChat' : 'onTapExercises'}}">
          <view class="icon-circle icon-circle-green qa-icon">
            <image class="qa-icon-img" src="{{item.icon}}" mode="aspectFit" />
          </view>
          <text class="qa-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 今日摘要 -->
    <view class="section-title animate-fade-in animate-delay-3">今日摘要</view>
    <view class="summary-card card animate-fade-in animate-delay-4" wx:if="{{todaySummary}}">
      <view class="summary-item" wx:for="{{todaySummary}}" wx:key="key">
        <view class="icon-circle-sm icon-circle-light summary-icon-wrap">
          <text class="summary-icon-text">{{item.iconText}}</text>
        </view>
        <view class="summary-info">
          <text class="summary-label">{{item.label}}</text>
          <text class="summary-value">{{item.value}}</text>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <view class="empty-icon">
        <text style="font-size: 40rpx; color: #22c55e;">○</text>
      </view>
      <text class="empty-text">今天还没有记录，快去分析体态吧！</text>
    </view>
  </block>
</view>
