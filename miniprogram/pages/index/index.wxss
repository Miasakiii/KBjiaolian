/* pages/index/index.wxss - 首页样式 */
.page-container { min-height: 100vh; background: #f8fafc; padding-bottom: env(safe-area-inset-bottom); }

/* 未登录 - 宣传 Banner */
.hero-banner {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  padding: 60rpx 40rpx 80rpx;
  border-radius: 0 0 40rpx 40rpx;
}
.hero-content { display: flex; flex-direction: column; align-items: center; }
.hero-title {
  font-size: 40rpx; font-weight: 700; color: #ffffff;
  text-align: center; margin-bottom: 16rpx;
}
.hero-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.85); text-align: center; margin-bottom: 40rpx; }
.hero-btn { width: 80% !important; font-size: 32rpx !important; border-radius: 40rpx !important; }

/* 功能网格 */
.features-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 20rpx; padding: 32rpx 24rpx;
}
.feature-card {
  background: #ffffff; border-radius: 16rpx; padding: 28rpx 20rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.feature-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.feature-name { font-size: 28rpx; font-weight: 600; color: #1c1c1e; margin-bottom: 8rpx; }
.feature-desc { font-size: 22rpx; color: #6b7280; text-align: center; }

/* 已登录 - 欢迎栏 */
.welcome-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 24rpx 16rpx;
}
.welcome-text { font-size: 32rpx; font-weight: 600; color: #1c1c1e; }
.plan-badge { font-size: 22rpx; }

/* 配额卡片 */
.quota-card { margin: 0 24rpx 20rpx; }
.quota-header { margin-bottom: 16rpx; }
.quota-title { font-size: 28rpx; font-weight: 600; }
.quota-upgrade { font-size: 24rpx; color: #22c55e; font-weight: 500; }
.quota-grid { display: flex; gap: 16rpx; }
.quota-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.quota-count { font-size: 36rpx; font-weight: 700; color: #22c55e; }
.quota-label { font-size: 20rpx; color: #6b7280; margin: 4rpx 0; }
.quota-bar-bg { width: 100%; height: 8rpx; background: #f1f5f9; border-radius: 4rpx; overflow: hidden; }
.quota-bar-fill { height: 100%; background: #22c55e; border-radius: 4rpx; transition: width 0.3s; }

/* 快捷操作 */
.quick-actions {
  display: flex; justify-content: space-around;
  padding: 24rpx 24rpx 8rpx;
}
.quick-action { display: flex; flex-direction: column; align-items: center; padding: 16rpx; }
.qa-icon {
  width: 96rpx; height: 96rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; margin-bottom: 12rpx;
}
.qa-analyze { background: #dcfce7; }
.qa-plan { background: #dbeafe; }
.qa-chat { background: #fef3c7; }
.qa-exercises { background: #f3e8ff; }
.qa-text { font-size: 24rpx; color: #374151; font-weight: 500; }

/* 今日摘要 */
.summary-card { margin: 0 24rpx 20rpx; }
.summary-item {
  display: flex; align-items: center; padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.summary-item:last-child { border-bottom: none; }
.summary-icon { font-size: 36rpx; margin-right: 20rpx; }
.summary-info { display: flex; flex-direction: column; }
.summary-label { font-size: 24rpx; color: #6b7280; }
.summary-value { font-size: 28rpx; font-weight: 500; color: #1c1c1e; }
