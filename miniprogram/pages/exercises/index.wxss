/* pages/exercises/index.wxss - 动作库页样式 */
.page-container { min-height: 100vh; background: #f8fafb; }

/* 搜索栏 */
.search-bar { padding: 20rpx 24rpx 12rpx; }
.search-input-wrap {
  display: flex; align-items: center; gap: 12rpx;
  background: #ffffff; border-radius: 16rpx; padding: 18rpx 24rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}
.search-icon-wrap { width: 32rpx; height: 32rpx; display: flex; align-items: center; justify-content: center; }
.search-icon-char { font-size: 24rpx; color: #d1d5db; }
.search-input { flex: 1; font-size: 28rpx; color: #111827; }

/* 肌群筛选 */
.filter-scroll { white-space: nowrap; padding: 8rpx 0; }
.filter-list { display: inline-flex; gap: 12rpx; padding: 0 24rpx; }
.filter-tag {
  display: inline-block; padding: 14rpx 28rpx; border-radius: 12rpx;
  background: #ffffff; color: #4b5563; font-size: 24rpx; flex-shrink: 0;
  border: 1rpx solid #f0f0f0;
}
.filter-tag-active { background: #ccfbf1; color: #0d5a54; border-color: #0f766e; font-weight: 600; }

/* 动作列表 */
.exercise-list { padding: 16rpx 24rpx 40rpx; }
.exercise-card {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx 24rpx; margin-bottom: 16rpx;
}
.ec-left { flex-shrink: 0; }
.ec-icon-wrap {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  background: linear-gradient(145deg, #ccfbf1, #f6f8f7);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(34, 197, 94, 0.12);
}
.ec-icon-text { font-size: 32rpx; font-weight: 700; color: #0d5a54; }
.ec-info { flex: 1; min-width: 0; }
.ec-name { font-size: 28rpx; font-weight: 600; color: #111827; display: block; }
.ec-group { font-size: 22rpx; color: #9ca3af; margin-top: 6rpx; display: block; }
.ec-desc { font-size: 22rpx; color: #d1d5db; margin-top: 6rpx; display: block; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.ec-arrow { flex-shrink: 0; }
.ec-arrow-char { font-size: 32rpx; color: #d1d5db; font-weight: 300; }

/* 详情弹窗 */
.detail-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 100;
  display: flex; align-items: flex-end; justify-content: center;
}
.detail-sheet {
  width: 100%; max-height: 80vh; background: #ffffff;
  border-radius: 28rpx 28rpx 0 0; padding: 36rpx 36rpx 52rpx;
  overflow-y: auto;
}
.ds-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32rpx; }
.ds-name { font-size: 34rpx; font-weight: 700; color: #111827; }
.ds-close { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #f8fafb; }
.ds-close-char { font-size: 36rpx; color: #9ca3af; font-weight: 300; }
.ds-close-icon { width: 32rpx; height: 32rpx; opacity: 0.6; }
.ds-body { }
.ds-row { display: flex; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.ds-label { font-size: 26rpx; color: #9ca3af; }
.ds-value { font-size: 26rpx; font-weight: 600; color: #111827; }
.ds-section { font-size: 28rpx; font-weight: 700; color: #111827; margin: 28rpx 0 16rpx; }
.ds-tips { }
.ds-tip-item { display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 12rpx; }
.ds-tip-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: #ccfbf1; margin-top: 14rpx; flex-shrink: 0; }
.ds-tip { font-size: 26rpx; color: #4b5563; line-height: 1.8; }
