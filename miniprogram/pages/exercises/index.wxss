/* pages/exercises/index.wxss - 动作库页 */
.page-container { min-height: 100vh; background: var(--bg); padding: 0 var(--sp-4) env(safe-area-inset-bottom); }

/* 搜索栏 */
.search-bar { padding: var(--sp-3) 0 var(--sp-2); }
.search-input-wrap { display: flex; align-items: center; gap: var(--sp-2); background: var(--surface); border: 1rpx solid var(--line-soft); border-radius: var(--radius); padding: var(--sp-2) var(--sp-3); }
.search-icon-wrap { display: flex; align-items: center; }
.search-icon-img { width: 32rpx; height: 32rpx; opacity: 0.4; }
.search-input { flex: 1; font-size: var(--fs-body); color: var(--text-1); }

/* 筛选 */
.filter-scroll { white-space: nowrap; margin: 0 calc(-1 * var(--sp-4)) var(--sp-2); padding: 0 var(--sp-4); }
.filter-list { display: inline-flex; gap: var(--sp-2); }
.filter-tag { display: inline-block; padding: 8rpx 24rpx; border-radius: 20rpx; font-size: var(--fs-caption); color: var(--text-2); background: var(--surface); border: 1rpx solid var(--line-soft); }
.filter-tag-active { background: var(--brand-soft); color: var(--brand); border-color: var(--brand-soft); font-weight: 600; }

/* 动作卡片 */
.exercise-list { display: flex; flex-direction: column; gap: var(--sp-2); }
.exercise-card { display: flex; align-items: center; gap: var(--sp-3); }
.ec-icon-wrap { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--brand-soft); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.ec-icon-img { width: 38rpx; height: 38rpx; }
.ec-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.ec-name { font-size: var(--fs-body); font-weight: 600; color: var(--text-1); }
.ec-group { font-size: var(--fs-label); color: var(--text-3); }
.ec-desc { font-size: var(--fs-caption); color: var(--text-2); }
.ec-arrow { width: 28rpx; height: 28rpx; transform: rotate(90deg); opacity: 0.4; flex-shrink: 0; }

/* 详情弹窗 */
.detail-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15, 23, 42, 0.5); z-index: 100; display: flex; align-items: flex-end; }
.detail-sheet { width: 100%; background: var(--surface); border-radius: var(--radius-lg) var(--radius-lg) 0 0; padding: var(--sp-4); padding-bottom: calc(var(--sp-5) + env(safe-area-inset-bottom)); }
.ds-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--sp-3); }
.ds-title-wrap { display: flex; align-items: center; gap: var(--sp-2); }
.ds-pattern-icon { width: 40rpx; height: 40rpx; }
.ds-name { font-size: var(--fs-h2); font-weight: 600; color: var(--text-1); }
.ds-close { width: 56rpx; height: 56rpx; border-radius: 50%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; }
.ds-close-icon { width: 32rpx; height: 32rpx; opacity: 0.6; }
.ds-body { display: flex; flex-direction: column; }
.ds-row { display: flex; justify-content: space-between; align-items: center; padding: var(--sp-2) 0; border-bottom: 1rpx solid var(--line-soft); }
.ds-label { font-size: var(--fs-caption); color: var(--text-3); }
.ds-value { font-size: var(--fs-body); color: var(--text-1); font-weight: 600; }
.ds-section { font-size: var(--fs-label); color: var(--text-3); letter-spacing: 2rpx; text-transform: uppercase; margin: var(--sp-3) 0 var(--sp-2); }
.ds-tips { display: flex; flex-direction: column; gap: var(--sp-2); }
.ds-tip-item { display: flex; align-items: center; gap: var(--sp-2); }
.ds-tip-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--brand); flex-shrink: 0; }
.ds-tip { font-size: var(--fs-caption); color: var(--text-2); }
