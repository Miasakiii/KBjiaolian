    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "assets/icons/home.png",
        "selectedIconPath": "assets/icons/home-active.png"
      },
      {
        "pagePath": "pages/analyze/index",
        "text": "分析",
        "iconPath": "assets/icons/analyze.png",
        "selectedIconPath": "assets/icons/analyze-active.png"
      },
      {
        "pagePath": "pages/plan/index",
        "text": "训练",
        "iconPath": "assets/icons/plan.png",
        "selectedIconPath": "assets/icons/plan-active.png"
      },
      {
        "pagePath": "pages/chat/index",
        "text": "对话",
        "iconPath": "assets/icons/chat.png",
        "selectedIconPath": "assets/icons/chat-active.png"
      },
      {
        "pagePath": "pages/exercises/index",
        "text": "动作库",
        "iconPath": "assets/icons/exercises.png",
        "selectedIconPath": "assets/icons/exercises-active.png"
      }
    ]
  },
  "subpackages": [
    {
      "root": "subpkg/user",
