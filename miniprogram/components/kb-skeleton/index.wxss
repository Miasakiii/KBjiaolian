/* kb-skeleton 分析结果页骨架屏样式 */

.kb-skeleton {
  overflow: hidden;
}

/* ====== 顶部圆形评分区 ====== */
.kb-skeleton__header {
  padding: var(--sp-5) 0 var(--sp-4);
}

.kb-skeleton__score-ring {
  width: 200rpx;
  height: 200rpx;
}

.kb-skeleton__score-num {
  width: 120rpx;
  height: 48rpx;
  margin-top: var(--sp-3);
  margin-left: auto;
  margin-right: auto;
}

.kb-skeleton__score-label {
  width: 80rpx;
  margin-top: var(--sp-1);
  margin-left: auto;
  margin-right: auto;
}

/* ====== 雷达图占位区 ====== */
.kb-skeleton__chart {
  display: flex;
  justify-content: center;
  padding: var(--sp-3) 0;
}

.kb-skeleton__chart-placeholder {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius);
}

/* ====== 底部文本行 ====== */
.kb-skeleton__lines {
  padding: var(--sp-3) 0 var(--sp-4);
}
