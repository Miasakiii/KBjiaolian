/* app.wxss - KB教练小程序全局样式 */
/* 品牌色：#22c55e  浅绿：#dcfce7  深绿：#16a34a */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1c1c1e;
  background-color: #f8fafc;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image {
  box-sizing: border-box;
}

/* ====== 色彩工具类 ====== */
.text-brand { color: #22c55e; }
.text-brand-dark { color: #16a34a; }
.text-gray { color: #6b7280; }
.text-gray-dark { color: #374151; }
.text-white { color: #ffffff; }
.text-red { color: #ef4444; }
.text-orange { color: #f97316; }

.bg-brand { background-color: #22c55e; }
.bg-brand-light { background-color: #dcfce7; }
.bg-white { background-color: #ffffff; }
.bg-gray-light { background-color: #f1f5f9; }

/* ====== 布局工具类 ====== */
.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* ====== 间距工具类 ====== */
.p-sm { padding: 16rpx; }
.p-md { padding: 24rpx; }
.p-lg { padding: 32rpx; }
.px-md { padding-left: 24rpx; padding-right: 24rpx; }
.py-md { padding-top: 24rpx; padding-bottom: 24rpx; }
.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 24rpx; }
.mb-sm { margin-bottom: 16rpx; }
.mb-md { margin-bottom: 24rpx; }
.mx-auto { margin-left: auto; margin-right: auto; }

/* ====== 卡片 ====== */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* ====== 按钮 ====== */
.btn-primary {
  background: #22c55e;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  width: 100%;
  line-height: 1.4;
}
.btn-primary:active { background: #16a34a; }

.btn-outline {
  background: transparent;
  color: #22c55e;
  border: 2rpx solid #22c55e;
  border-radius: 12rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  width: 100%;
  line-height: 1.4;
}
.btn-outline:active { background: #dcfce7; }

.btn-disabled {
  background: #d1d5db;
  color: #9ca3af;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
  width: 100%;
  line-height: 1.4;
}

/* ====== 标题 ====== */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
  padding: 24rpx 24rpx 12rpx;
}

/* ====== 分割线 ====== */
.divider {
  height: 1rpx;
  background: #e5e7eb;
  margin: 16rpx 0;
}

/* ====== 徽章 ====== */
.badge {
  display: inline-block;
  background: #dcfce7;
  color: #16a34a;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.badge-pro {
  background: #fef3c7;
  color: #d97706;
}

/* ====== 输入框 ====== */
.input-wrap {
  background: #f1f5f9;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}
.input-wrap:focus-within {
  border-color: #22c55e;
  background: #ffffff;
}

/* ====== 加载动画 ====== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: #9ca3af;
}
.empty-state .empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-state .empty-text { font-size: 28rpx; }

/* ====== 安全区域（适配全面屏） ====== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
