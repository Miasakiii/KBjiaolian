<!--subpkg/history/compare/index.wxml - 前后对比页-->
<view class="page-container">
  <view class="section-title">选择两次分析记录</view>
  <text class="hint-text">选择两次体态分析，AI 将生成变化报告</text>

  <!-- 已选记录展示 -->
  <view class="selected-wrap" wx:if="{{selected.length > 0}}">
    <view class="selected-card card-flat" wx:for="{{selected}}" wx:key="id">
      <text class="sc-date">{{item.dateStr}}</text>
      <text class="sc-score">综合 {{item.overallScore}} 分</text>
      <view class="sc-remove" bindtap="onRemove" data-idx="{{index}}">✕</view>
    </view>
  </view>

  <!-- 记录列表（选择模式）-->
  <view class="record-list">
    <view
      class="record-card card-flat {{item.selected ? 'record-card-active' : ''}}"
      wx:for="{{list}}"
      wx:key="id"
      bindtap="onToggleSelect"
      data-id="{{item.id}}"
    >
      <view class="rc-header flex-between">
        <text class="rc-date">{{item.dateStr}}</text>
        <text class="rc-score">{{item.overallScore}}分</text>
      </view>
      <view class="rc-badge" wx:if="{{item.selected}}">已选</view>
    </view>
  </view>

  <!-- 对比结果 -->
  <view wx:if="{{compareResult}}" class="compare-result animate-fade-in">
    <view class="section-title">评分变化</view>
    <view class="card-flat score-change-card">
      <text class="score-change-value {{compareResult.scoreChange >= 0 ? 'text-brand' : 'text-warn'}}">
        {{compareResult.scoreChange >= 0 ? '+' : ''}}{{compareResult.scoreChange}}
      </text>
      <text class="score-change-from" wx:if="{{compareResult.scoreA}}">{{compareResult.scoreA}} → {{compareResult.scoreB}}</text>
    </view>

    <view class="section-title">维度对比</view>
    <view class="radar-wrap">
      <kb-radar mode="compare" size="{{260}}" data="{{compareResult.radarB}}" prevData="{{compareResult.radarA}}" />
    </view>

    <view class="section-title">维度变化</view>
    <view class="card-flat dim-change-card" wx:if="{{compareResult.dims}}">
      <view class="dim-change-row" wx:for="{{compareResult.dims}}" wx:key="name">
        <image class="dim-change-icon" src="/assets/icons/body-{{item.iconKey}}.svg" mode="aspectFit" />
        <text class="dim-change-name">{{item.name}}</text>
        <text class="dim-change-from" wx:if="{{item.before}}">{{item.before}}→{{item.after}}</text>
        <text class="dim-change-delta {{item.change >= 0 ? 'text-brand' : 'text-warn'}}">
          {{item.change >= 0 ? '↑' : '↓'}}{{item.change >= 0 ? '+' : ''}}{{item.change}}
        </text>
      </view>
    </view>

    <text class="compare-summary" wx:if="{{compareResult.summary}}">{{compareResult.summary}}</text>
  </view>

  <button class="btn-primary compare-btn" bindtap="onCompare" loading="{{loading}}" disabled="{{selected.length < 2}}">
    {{selected.length < 2 ? '请选择 2 条记录' : '生成对比报告'}}
  </button>
</view>
