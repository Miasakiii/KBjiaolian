/* subpkg/history/compare/index.wxss - 前后对比页 */
.page-container { min-height: 100vh; background: var(--bg); padding: 0 var(--sp-4) env(safe-area-inset-bottom); }
.hint-text { font-size: var(--fs-caption); color: var(--text-3); padding: 0 0 var(--sp-3); display: block; }

/* 已选记录 */
.selected-wrap { display: flex; flex-direction: column; gap: var(--sp-2); margin-bottom: var(--sp-3); }
.selected-card { display: flex; align-items: center; gap: var(--sp-2); position: relative; }
.sc-date { font-size: var(--fs-body); color: var(--text-1); font-weight: 600; flex: 1; }
.sc-score { font-size: var(--fs-caption); color: var(--brand); font-weight: 600; }
.sc-remove { font-size: var(--fs-caption); color: var(--text-3); padding: var(--sp-1); display: flex; align-items: center; }
.sc-remove-icon { width: 28rpx; height: 28rpx; opacity: 0.6; }

/* 记录列表 */
.record-list { display: flex; flex-direction: column; gap: var(--sp-2); }
.record-card { position: relative; }
.record-card-active { border-color: var(--brand); background: var(--brand-soft); }
.rc-header { display: flex; justify-content: space-between; align-items: center; }
.rc-date { font-size: var(--fs-body); color: var(--text-1); }
.rc-score { font-size: var(--fs-caption); color: var(--brand); font-weight: 600; }
.rc-badge { position: absolute; top: var(--sp-2); right: var(--sp-2); font-size: var(--fs-label); color: var(--brand); background: var(--surface); padding: 2rpx 12rpx; border-radius: 20rpx; font-weight: 600; }

/* 对比结果 */
.score-change-card { text-align: center; }
.score-change-value { font-size: var(--fs-display); font-weight: 600; display: block; line-height: 1.1; font-variant-numeric: tabular-nums; }
.score-change-from { font-size: var(--fs-caption); color: var(--text-3); margin-top: var(--sp-1); display: block; }
.radar-wrap { display: flex; justify-content: center; padding: var(--sp-3) 0; }
.dim-change-row { display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-2) 0; border-bottom: 1rpx solid var(--line-soft); }
.dim-change-row:last-child { border-bottom: none; }
.dim-change-icon { width: 32rpx; height: 32rpx; }
.dim-change-name { flex: 1; font-size: var(--fs-body); color: var(--text-2); }
.dim-change-from { font-size: var(--fs-caption); color: var(--text-3); font-variant-numeric: tabular-nums; }
.dim-change-delta { font-size: var(--fs-caption); font-weight: 600; font-variant-numeric: tabular-nums; }
.compare-summary { font-size: var(--fs-caption); color: var(--text-2); line-height: 1.6; margin: var(--sp-3) 0; display: block; }
.compare-btn { margin: var(--sp-4) 0; }
