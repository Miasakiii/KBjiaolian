/* subpkg/user/privacy/index.wxss - 法律文档页通用样式 */
.legal-page { min-height: 100vh; background: var(--bg); padding: var(--sp-4) var(--sp-4) calc(var(--sp-5) + env(safe-area-inset-bottom)); }

.legal-header { margin-bottom: var(--sp-4); padding-bottom: var(--sp-3); border-bottom: 1rpx solid var(--line-soft); }
.legal-title { font-size: var(--fs-title); font-weight: 600; color: var(--text-1); display: block; }
.legal-update { font-size: var(--fs-label); color: var(--text-3); margin-top: var(--sp-1); display: block; }

.legal-intro { padding: var(--sp-3); background: var(--surface); border-radius: var(--radius-md); margin-bottom: var(--sp-4); }
.legal-intro text { font-size: var(--fs-body); color: var(--text-2); line-height: 1.7; }

.legal-section { margin-bottom: var(--sp-4); }
.legal-section-title { font-size: var(--fs-h2); font-weight: 600; color: var(--brand); display: block; margin-bottom: var(--sp-2); }
.legal-text { font-size: var(--fs-body); color: var(--text-2); line-height: 1.8; display: block; margin-bottom: var(--sp-1); }

.legal-block { margin-top: var(--sp-2); padding: var(--sp-2) var(--sp-3); background: var(--surface); border-radius: var(--radius-sm); }
.legal-block-title { font-size: var(--fs-body); font-weight: 600; color: var(--text-1); display: block; margin-bottom: var(--sp-1); }

.legal-footer { margin-top: var(--sp-5); padding-top: var(--sp-3); border-top: 1rpx solid var(--line-soft); text-align: center; }
.legal-footer-text { font-size: var(--fs-label); color: var(--text-3); }
