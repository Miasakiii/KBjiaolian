/* subpkg/user/pricing/index.wxss */
.page-container { min-height: 100vh; background: #f8fafc; padding-bottom: 40rpx; }
.pricing-header { padding: 40rpx 32rpx 20rpx; text-align: center; }
.ph-title { font-size: 36rpx; font-weight: 700; display: block; }
.ph-desc { font-size: 26rpx; color: #6b7280; display: block; margin-top: 8rpx; }

.plan-cards { padding: 0 24rpx; }
.plan-card { position: relative; border: 2rpx solid transparent; transition: border-color 0.2s; }
.plan-card-active { border-color: #22c55e; }
.plan-card-pro { border-color: #f97316; }
.pc-badge {
  position: absolute; top: 0; right: 0; background: #22c55e; color: #fff;
  font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 0 16rpx 0 12rpx;
}
.pc-badge-hot { background: #f97316; }
.pc-name { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.pc-price { font-size: 56rpx; font-weight: 700; color: #22c55e; }
.pc-unit { font-size: 26rpx; font-weight: 400; }
.pc-price-year { font-size: 22rpx; color: #6b7280; display: block; margin: 4rpx 0 16rpx; }
.pc-features { display: flex; flex-direction: column; gap: 10rpx; }
.pc-feat { font-size: 26rpx; color: #374151; }
.pc-feat-disabled { color: #9ca3af; text-decoration: line-through; }

.pricing-btn { margin: 32rpx 24rpx 0; font-size: 32rpx !important; border-radius: 40rpx !important; }
