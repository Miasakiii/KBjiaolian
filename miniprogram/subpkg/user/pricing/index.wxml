<!--subpkg/user/pricing/index.wxml - 套餐定价页-->
<view class="page-container">
  <view class="pricing-header">
    <text class="ph-title">选择你的套餐</text>
    <text class="ph-desc">解锁完整 AI 体能评估与训练方案</text>
  </view>

  <view class="plan-cards">
    <view
      class="plan-card card-flat {{selectedPlan === item.key ? 'plan-card-active' : ''}} {{item.key !== 'free' ? 'plan-card-pro' : ''}}"
      wx:for="{{planList}}"
      wx:key="key"
      bindtap="onSelectPlan"
      data-plan="{{item.key}}"
    >
      <view class="pc-badge {{item.isCurrent ? '' : 'pc-badge-hot'}}" wx:if="{{item.badge || item.isCurrent}}">{{item.isCurrent ? '当前方案' : item.badge}}</view>
      <text class="pc-name">{{item.name}}</text>
      <view class="pc-price-row">
        <text class="pc-price">¥{{item.price}}</text>
        <text class="pc-unit" wx:if="{{item.period}}">{{item.period}}</text>
      </view>
      <view class="pc-features">
        <view class="pc-feat-item" wx:for="{{item.features}}" wx:key="text" wx:for-item="feat">
          <image src="/assets/icons/st-ok.svg" mode="aspectFit" class="pc-feat-icon" />
          <text class="pc-feat">{{feat.text}}</text>
        </view>
      </view>
    </view>
  </view>

  <button class="btn-primary pricing-btn" bindtap="onConfirmPlan" loading="{{paying}}">
    {{selectedPlan === 'free' ? '当前已是 Free' : '立即开通'}}
  </button>
</view>
