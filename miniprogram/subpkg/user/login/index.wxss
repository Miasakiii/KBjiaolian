/* subpkg/user/login/index.wxss - 登录页样式 */
.page-container { min-height: 100vh; background: #f8fafb; display: flex; flex-direction: column; }
.login-hero {
  background: linear-gradient(160deg, #22c55e 0%, #059669 100%);
  padding: 100rpx 40rpx 80rpx; display: flex; flex-direction: column; align-items: center;
  border-radius: 0 0 48rpx 48rpx;
}
.lh-icon-wrap {
  width: 120rpx; height: 120rpx; border-radius: 32rpx;
  background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
}
.lh-icon-text { font-size: 44rpx; font-weight: 800; color: #ffffff; letter-spacing: 2rpx; }
.lh-title { font-size: 44rpx; font-weight: 700; color: #ffffff; }
.lh-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; }
.login-actions { padding: 48rpx 40rpx; }
.login-btn { font-size: 32rpx !important; border-radius: 40rpx !important; }
.login-divider { display: flex; align-items: center; gap: 16rpx; margin: 32rpx 0; }
.ld-line { flex: 1; height: 1rpx; background: #e5e7eb; }
.ld-text { font-size: 24rpx; color: #9ca3af; }
.email-form { display: flex; flex-direction: column; gap: 16rpx; }
.form-link { text-align: center; font-size: 26rpx; color: #22c55e; margin-top: 16rpx; }
