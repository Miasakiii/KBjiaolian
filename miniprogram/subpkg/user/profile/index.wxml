<!--subpkg/user/profile/index.wxml - 个人中心-->
<view class="page-container">
  <view class="profile-header">
    <image class="ph-avatar" src="{{user.avatar || '/assets/icons/profile.png'}}" />
    <text class="ph-name">{{user.nickname || '微信用户'}}</text>
    <view class="ph-plan-badge {{user.plan === 'pro' ? 'ph-badge-pro' : 'ph-badge-free'}}">
      {{user.plan === 'pro' ? 'Pro 会员' : 'Free'}}
    </view>
  </view>

  <view class="menu-list card-flat">
    <view class="menu-item" bindtap="onTapPricing">
      <view class="mi-icon-wrap"><image src="/assets/icons/tab-exercises.svg" mode="aspectFit" class="mi-icon-img" /></view>
      <text class="mi-label">升级套餐</text>
      <image src="/assets/icons/st-up.svg" mode="aspectFit" class="mi-arrow" />
    </view>
    <view class="menu-item" bindtap="onTapHistory">
      <view class="mi-icon-wrap"><image src="/assets/icons/tab-analyze.svg" mode="aspectFit" class="mi-icon-img" /></view>
      <text class="mi-label">历史记录</text>
      <image src="/assets/icons/st-up.svg" mode="aspectFit" class="mi-arrow" />
    </view>
    <view class="menu-item" bindtap="onTapAbout">
      <view class="mi-icon-wrap"><image src="/assets/icons/st-info.svg" mode="aspectFit" class="mi-icon-img" /></view>
      <text class="mi-label">关于 KB 教练</text>
      <image src="/assets/icons/st-up.svg" mode="aspectFit" class="mi-arrow" />
    </view>
  </view>

  <view class="menu-list card-flat">
    <view class="menu-item" bindtap="onTapLogout">
      <view class="mi-icon-wrap mi-icon-red"><image src="/assets/icons/st-close-red.svg" mode="aspectFit" class="mi-icon-img" /></view>
      <text class="mi-label text-logout">退出登录</text>
      <image src="/assets/icons/st-up.svg" mode="aspectFit" class="mi-arrow" />
    </view>
  </view>
</view>
