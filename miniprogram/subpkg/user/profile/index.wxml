<!--subpkg/user/profile/index.wxml - 个人中心-->
<view class="page-container">
  <view class="profile-header">
    <image class="ph-avatar" src="{{user.avatar || '/assets/icons/profile.png'}}" />
    <text class="ph-name">{{user.nickname || '微信用户'}}</text>
    <view class="ph-plan-badge badge {{user.plan === 'pro' ? 'badge-pro' : ''}}">
      {{user.plan === 'pro' ? 'Pro 会员' : 'Free'}}
    </view>
  </view>

  <view class="menu-list card">
    <view class="menu-item" bindtap="onTapPricing">
      <view class="mi-icon-wrap mi-icon-green">
        <text class="mi-icon-char">P</text>
      </view>
      <text class="mi-label">升级套餐</text>
      <text class="mi-arrow-char">›</text>
    </view>
    <view class="menu-item" bindtap="onTapHistory">
      <view class="mi-icon-wrap mi-icon-green">
        <text class="mi-icon-char">H</text>
      </view>
      <text class="mi-label">历史记录</text>
      <text class="mi-arrow-char">›</text>
    </view>
    <view class="menu-item" bindtap="onTapAbout">
      <view class="mi-icon-wrap mi-icon-green">
        <text class="mi-icon-char">i</text>
      </view>
      <text class="mi-label">关于 KB 教练</text>
      <text class="mi-arrow-char">›</text>
    </view>
  </view>

  <view class="menu-list card">
    <view class="menu-item" bindtap="onTapLogout">
      <view class="mi-icon-wrap mi-icon-red">
        <image src="/assets/icons/st-close-red.svg" mode="aspectFit" class="mi-icon-char mi-icon-img" />
      </view>
      <text class="mi-label text-red">退出登录</text>
      <text class="mi-arrow-char">›</text>
    </view>
  </view>
</view>
