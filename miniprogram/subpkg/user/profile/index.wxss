/* subpkg/user/profile/index.wxss */
.page-container { min-height: 100vh; background: #f8fafc; padding-bottom: 40rpx; }
.profile-header {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  padding: 60rpx 40rpx 48rpx; display: flex; flex-direction: column;
  align-items: center; border-radius: 0 0 40rpx 40rpx;
}
.ph-avatar { width: 128rpx; height: 128rpx; border-radius: 50%; background: rgba(255,255,255,0.2); margin-bottom: 16rpx; }
.ph-name { font-size: 34rpx; font-weight: 600; color: #fff; margin-bottom: 12rpx; }
.ph-plan-badge { font-size: 24rpx; }

.menu-list { margin: 20rpx 24rpx; }
.menu-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx 20rpx; border-bottom: 1rpx solid #f1f5f9;
}
.menu-item:last-child { border-bottom: none; }
.mi-icon { font-size: 36rpx; width: 48rpx; text-align: center; }
.mi-label { flex: 1; font-size: 28rpx; }
.mi-arrow { font-size: 22rpx; color: #d1d5db; }
