/* subpkg/user/payment/index.wxss - 支付确认页 */
.page-container { min-height: 100vh; background: var(--bg); padding: 0 var(--sp-4) env(safe-area-inset-bottom); }
.pay-section-label { font-size: var(--fs-label); color: var(--text-3); letter-spacing: 2rpx; display: block; margin-bottom: var(--sp-2); }
.pay-card { margin-bottom: var(--sp-3); }
.pc-plan-name { font-size: var(--fs-h2); font-weight: 600; color: var(--text-1); display: block; }
.pc-price-wrap { display: flex; align-items: baseline; gap: 4rpx; margin-top: var(--sp-1); }
.pc-price { font-size: var(--fs-display); font-weight: 600; color: var(--brand); font-variant-numeric: tabular-nums; line-height: 1.1; }
.pc-period { font-size: var(--fs-caption); color: var(--text-3); }

.pay-method { margin-bottom: var(--sp-3); }
.pm-option { display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-2) 0; border: 2rpx solid var(--line-soft); border-radius: var(--radius-sm); padding: var(--sp-3); }
.pm-active { border-color: var(--brand); background: var(--brand-soft); }
.pm-icon-wrap { width: 56rpx; height: 56rpx; border-radius: var(--radius-sm); background: var(--brand); display: flex; align-items: center; justify-content: center; }
.pm-icon-char { font-size: var(--fs-caption); font-weight: 600; color: #fff; }
.pm-name { flex: 1; font-size: var(--fs-body); font-weight: 600; color: var(--text-1); }
.pm-check { display: flex; align-items: center; justify-content: center; }
.pm-check-icon { width: 32rpx; height: 32rpx; }

.pay-notice { padding: var(--sp-2) 0; display: flex; flex-wrap: wrap; align-items: center; }
.pn-text { font-size: var(--fs-label); color: var(--text-3); }
.pn-link { font-size: var(--fs-label); color: var(--brand); }

.pay-footer { position: fixed; left: 0; right: 0; bottom: 0; display: flex; align-items: center; gap: var(--sp-3); padding: var(--sp-3) var(--sp-4) calc(var(--sp-3) + env(safe-area-inset-bottom)); background: var(--surface); border-top: 1rpx solid var(--line-soft); }
.pf-total { display: flex; flex-direction: column; }
.pf-label { font-size: var(--fs-label); color: var(--text-3); }
.pf-amount { font-size: var(--fs-title); font-weight: 600; color: var(--brand); font-variant-numeric: tabular-nums; }
.pf-btn { width: auto; flex: 1; padding: 22rpx 48rpx; }
