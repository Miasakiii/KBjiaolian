<!--subpkg/user/payment/index.wxml - 支付确认页-->
<view class="page-container">
  <view class="pay-card card">
    <text class="pc-title">确认订单</text>
    <view class="pc-plan-name">{{planName}}</view>
    <view class="pc-price-wrap">
      <text class="pc-price">¥{{price}}</text>
      <text class="pc-period">/{{period === 'year' ? '年' : '月'}}</text>
    </view>
  </view>

  <view class="pay-method card">
    <text class="pm-title">支付方式</text>
    <view class="pm-option pm-active">
      <view class="pm-icon-wrap">
        <text class="pm-icon-char">微</text>
      </view>
      <text class="pm-name">微信支付</text>
      <view class="pm-check"><image src="/assets/icons/st-ok.svg" mode="aspectFit" class="pm-check-icon" /></view>
    </view>
  </view>

  <view class="pay-notice">
    <text class="pn-text">支付即表示同意《用户协议》和《隐私政策》</text>
  </view>

  <view class="pay-footer safe-bottom">
    <view class="pf-total">
      <text class="pf-label">合计：</text>
      <text class="pf-amount">¥{{price}}</text>
    </view>
    <button class="btn-primary pf-btn" bindtap="onPay" loading="{{paying}}">
      确认支付
    </button>
  </view>
</view>
